{
  "name": "kcode",
  "displayName": "Kcode",
  "description": "Kcode - AI Agent Powered Development Environment (VS Code Extension)",
  "version": "0.2.0",
  "publisher": "kcode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:kcode.viewsMain"
  ],
  "icon": "resources/kcode.png",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kcode",
          "title": "Kcode",
          "icon": "resources/kcode.png"
        }
      ]
    },
    "views": {
      "kcode": [
        {
          "type": "webview",
          "id": "kcode.viewsMain",
          "name": "Kcode"
        }
      ]
    },
    "commands": [
      {
        "command": "kcode.open",
        "title": "Kcode: Open"
      },
      {
        "command": "kcode.newTask",
        "title": "Kcode: New Task"
      },
      {
        "command": "kcode.importGitHubIssue",
        "title": "Kcode: Import GitHub Issue"
      },
      {
        "command": "kcode.openSettings",
        "title": "Kcode: Open Settings"
      },
      {
        "command": "kcode.openReactView",
        "title": "Kcode: Open React View"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p tsconfig.build.json && node scripts/build-webview.js && npm run compile:react",
    "compile:react": "vite build",
    "dev:webview": "vite build --watch",
    "watch": "tsc -watch -p ./",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "package": "npx @vscode/vsce package --allow-missing-repository",
    "build:install": "npm run package && code --install-extension kcode-0.2.0.vsix"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.24.0",
    "@tailwindcss/vite": "^4.3.0",
    "better-sqlite3": "^12.10.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.10.10",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^0.562.0",
    "marked": "^18.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.6.6",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.96.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vscode/vsce": "^3.4.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  }
}
