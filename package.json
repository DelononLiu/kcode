{
  "name": "kcode",
  "displayName": "KCode",
  "description": "KCode - AI Agent Powered Development Environment (VS Code Extension)",
  "version": "0.1.0",
  "publisher": "kcode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kcode.open",
        "title": "KCode: Open"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0"
  }
}
