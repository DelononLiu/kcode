{
  "name": "kcode",
  "displayName": "Kcode",
  "description": "Kcode - AI Agent Powered Development Environment (VS Code Extension)",
  "version": "0.1.0",
  "publisher": "kcode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:kcode.viewsMain"
  ],
  "icon": "resources/kcode.png",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kcode",
          "title": "Kcode",
          "icon": "resources/kcode.png"
        }
      ]
    },
    "views": {
      "kcode": [
        {
          "type": "webview",
          "id": "kcode.viewsMain",
          "name": "Kcode"
        }
      ]
    },
    "commands": [
      {
        "command": "kcode.open",
        "title": "Kcode: Open"
      },
      {
        "command": "kcode.newTask",
        "title": "Kcode: New Task"
      }
    ],
    "configuration": {
      "title": "Kcode",
      "properties": {
        "kcode.agentName": {
          "type": "string",
          "default": "fake",
          "description": "Agent name or executable path. Set to \"fake\" to use built-in FakeAgent for debugging (no real agent required)."
        },
        "kcode.agentArgs": {
          "type": "array",
          "default": [],
          "description": "Additional arguments passed to the agent"
        },
        "kcode.agentUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8080",
          "description": "HTTP URL of a remote ACP agent (e.g. http://127.0.0.1:8080). When set, connects via HTTP instead of spawning a subprocess."
        },
        "kcode.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key for the built-in OpenAI agent. Falls back to OPENAI_API_KEY environment variable."
        },
        "kcode.openaiModel": {
          "type": "string",
          "default": "deepseek-v4-flash",
          "description": "OpenAI model name for the built-in OpenAI agent. Falls back to OPENAI_MODEL environment variable."
        },
        "kcode.opencodePath": {
          "type": "string",
          "default": "opencode",
          "description": "Path to the opencode executable. Used when kcode.agentName is \"opencode\"."
        },
        "kcode.openaiBaseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "OpenAI API base URL for the built-in OpenAI agent. Falls back to OPENAI_BASE_URL environment variable."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node scripts/build-webview.js",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "package": "npx @vscode/vsce package --allow-missing-repository",
    "build:install": "npm run package && code --install-extension kcode-0.1.0.vsix"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.4.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0"
  }
}
