{
  "name": "kcode",
  "displayName": "Kcode",
  "description": "Kcode - AI Agent Powered Development Environment (VS Code Extension)",
  "version": "0.2.0",
  "publisher": "kcode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:kcode.viewsMain"
  ],
  "icon": "resources/kcode.png",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kcode",
          "title": "Kcode",
          "icon": "resources/kcode.png"
        }
      ]
    },
    "views": {
      "kcode": [
        {
          "type": "webview",
          "id": "kcode.viewsMain",
          "name": "Kcode"
        }
      ]
    },
    "commands": [
      {
        "command": "kcode.open",
        "title": "Kcode: Open"
      },
      {
        "command": "kcode.newTask",
        "title": "Kcode: New Task"
      },
      {
        "command": "kcode.importGitHubIssue",
        "title": "Kcode: Import GitHub Issue"
      },
      {
        "command": "kcode.openSettings",
        "title": "Kcode: Open Settings"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p tsconfig.build.json && node scripts/build-webview.js",
    "watch": "tsc -watch -p ./",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "build:webview-ui": "cd src/webview-ui && npx vite build",
    "package": "npx @vscode/vsce package --allow-missing-repository",
    "build:install": "npm run package && code --install-extension kcode-0.2.0.vsix"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.24.0",
    "better-sqlite3": "^12.10.0",
    "highlight.js": "^11.11.1",
    "jsonc-parser": "^3.3.1",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.96.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vscode/vsce": "^3.4.0",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.5"
  }
}
