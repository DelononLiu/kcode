{
  "name": "kcode",
  "displayName": "KCode",
  "description": "KCode - AI Agent Powered Development Environment (VS Code Extension)",
  "version": "0.1.0",
  "publisher": "kcode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:kcode.viewsMain"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kcode",
          "title": "KCode",
          "icon": "resources/kcode.png"
        }
      ]
    },
    "views": {
      "kcode": [
        {
          "type": "webview",
          "id": "kcode.viewsMain",
          "name": "KCode"
        }
      ]
    },
    "commands": [
      {
        "command": "kcode.open",
        "title": "KCode: Open"
      },
      {
        "command": "kcode.newTask",
        "title": "KCode: New Task"
      }
    ],
    "configuration": {
      "title": "KCode",
      "properties": {
        "kcode.agentName": {
          "type": "string",
          "default": "fake",
          "description": "Agent name or executable path. Set to \"fake\" to use built-in FakeAgent for debugging (no real agent required)."
        },
        "kcode.agentArgs": {
          "type": "array",
          "default": [],
          "description": "Additional arguments passed to the agent"
        },
        "kcode.agentUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8080",
          "description": "HTTP URL of a remote ACP agent (e.g. http://127.0.0.1:8080). When set, connects via HTTP instead of spawning a subprocess."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0"
  }
}
